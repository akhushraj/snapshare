{
  "manifest_version": 3,
  "name": "Screenshot",
  "version": "1.0.0",
  "description": "Capture full pages, annotate, and share via Google Drive — no server needed.",

  "permissions": [
    "activeTab",
    "tabs",
    "debugger",
    "identity",
    "storage",
    "unlimitedStorage",
    "scripting",
    "clipboardWrite"
  ],

  "host_permissions": [
    "https://www.googleapis.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "SnapShare — Take Screenshot",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "oauth2": {
    "client_id": "153536487889-crvhlcfpuigq4gegpgbmbft7kj1bok2c.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file",
      "https://www.googleapis.com/auth/userinfo.email"
    ]
  }
}
